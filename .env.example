# Token del bot de Telegram (obtener con @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# API de fútbol https://www.football-data.org/ (registro gratuito, datos temporada actual)
# Sin token solo listados básicos; con token: tablas, partidos, predicciones
FOOTBALL_API_TOKEN=

# ── Scheduler automático ──────────────────────────────────────────────────
# Se activa al iniciar la API (uvicorn).  Poner false para desactivar.
SCHEDULER_ENABLED=true
# Cada cuantas horas sincronizar fixtures + stats + predicciones
SCHEDULER_SYNC_HOURS=6
# Cada cuantas horas hacer rolling retrain + backtest (168 = 7 días)
SCHEDULER_RETRAIN_HOURS=168
