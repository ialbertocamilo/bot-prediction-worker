# ── Provider activo ─────────────────────────────────────────
# Opciones: api-football | football-data-org | espn-scraper | composite | transfermarkt | sofascore
ACTIVE_PROVIDER=espn-scraper

DEFAULT_LEAGUE_ID=670
DEFAULT_SEASON=2026

# ── ESPN Scraper (gratis, sin API key) ──────────────────────
# Slug de la liga: per.1, arg.1, bra.1, col.1, mex.1, eng.1, esp.1, etc.
ESPN_LEAGUE_SLUG=per.1

# ── API-Football ────────────────────────────────────────────
API_FOOTBALL_KEY=554fdf3e0efd245f802eb8fdcecad3d4

# ── football-data.org ───────────────────────────────────────
# Regístrate gratis en https://www.football-data.org
# IDs: PL=2021, BL1=2002, PD=2014, SA=2019, FL1=2015, CL=2001, BSA=2013
FOOTBALL_DATA_ORG_KEY=

# ── Transfermarkt (scraper HTML, gratis, sin API key) ───────
# Path de la liga en Transfermarkt
# Perú: liga-1/startseite/wettbewerb/PE1
# Argentina: superliga/startseite/wettbewerb/AR1N
# Brasil: campeonato-brasileiro-serie-a/startseite/wettbewerb/BRA1
TRANSFERMARKT_LEAGUE_PATH=liga-1/startseite/wettbewerb/PE1

# ── SofaScore (API JSON pública, gratis, sin API key) ───────
# ID del torneo en SofaScore (Liga 1 Perú = 406)
SOFASCORE_TOURNAMENT_ID=406
# ID de la temporada (cambia cada año, buscar en SofaScore)
SOFASCORE_SEASON_ID=88529

# ── Composite (multi-provider) ─────────────────────────────
# Formato: league_id:provider_name,league_id:provider_name,...
# Ejemplo: liga peruana via scraper + PL via football-data.org
# ACTIVE_PROVIDER=composite
# COMPOSITE_ROUTES=670:espn-scraper,2021:football-data-org
# COMPOSITE_DEFAULT=espn-scraper

# ── Base de datos ───────────────────────────────────────────
DATABASE_URL=
SYNC_DAYS_BACK=60
SYNC_DAYS_AHEAD=14

SCHEDULER_ENABLED=false
SCHEDULER_SYNC_HOURS=6          
SCHEDULER_RETRAIN_HOURS=168  